# llm-board — a peer-review harness for multi-LLM panels.
# Routes every request through OpenRouter. One key, any provider.

# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# -------------------------------------------------------------------------
# Roster override (optional)
# -------------------------------------------------------------------------
# The harness ships with a sensible 3-model default in src/lib/board.ts.
# Override here to use any models OpenRouter routes — minimum two, no upper
# bound. Format: `id|slug|label` triples, comma-separated. The pipe lets
# free-tier slugs like `model:free` round-trip without ambiguity.
# -------------------------------------------------------------------------

# --- Free-tier preset (no credits required) ----------------------------------
# Picks three diverse free models. See the README "Run it free" section for
# the per-day request budget on the OpenRouter free tier.
# BOARD_ROSTER="llama|meta-llama/llama-3.3-70b-instruct:free|Llama 3.3 70B,qwen|qwen/qwen3-next-80b-a3b-instruct:free|Qwen 3 Next 80B,gptoss|openai/gpt-oss-120b:free|GPT-OSS 120B"

# --- Paid frontier preset ----------------------------------------------------
# BOARD_ROSTER="opus|anthropic/claude-opus-4|Claude Opus 4,gemini|google/gemini-2.5-pro|Gemini 2.5 Pro,qwen|qwen/qwen3-max|Qwen 3 Max"

# --- Chairman override -------------------------------------------------------
# Must match one of the ids above. Falls back to the first member if unset
# or invalid.
# CHAIRMAN_ID=opus

# --- OpenRouter attribution (optional) ---------------------------------------
# Shown in OpenRouter's dashboard and helps with model-routing analytics.
# OPENROUTER_REFERER=http://localhost:3000
# OPENROUTER_TITLE=llm-board
