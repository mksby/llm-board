# llm-board — a peer-review harness for multi-LLM panels.
# Routes every request through OpenRouter. One key, any provider.

# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# -------------------------------------------------------------------------
# Roster override (optional)
# -------------------------------------------------------------------------
# The harness ships with a sensible 3-model default in src/lib/board.ts.
# Override here to use any models OpenRouter routes — minimum two, no upper
# bound.
#
# Format: `id|slug|label[|lens]` per member, comma-separated. The pipe
# separator lets free-tier slugs like `model:free` round-trip without
# ambiguity. The optional 4th field assigns a thinking-style lens:
#   contrarian | first-principles | expansionist | outsider | executor
#
# Slugs below are valid against the OpenRouter catalogue as of 2026-06-10.
# See README "Notable models on OpenRouter" for a full picker.
# -------------------------------------------------------------------------

# --- FREE-TIER PRESETS -------------------------------------------------------

# Free, 3 members, no lenses (diverse providers: Meta · Alibaba · OpenAI OSS)
# BOARD_ROSTER="llama|meta-llama/llama-3.3-70b-instruct:free|Llama 3.3 70B,qwen|qwen/qwen3-next-80b-a3b-instruct:free|Qwen 3 Next 80B,gptoss|openai/gpt-oss-120b:free|GPT-OSS 120B"

# Free, full council, all 5 lenses (5 providers, 5 angles)
# BOARD_ROSTER="c|meta-llama/llama-3.3-70b-instruct:free|Llama 3.3 70B|contrarian,fp|qwen/qwen3-next-80b-a3b-instruct:free|Qwen 3 Next 80B|first-principles,e|openai/gpt-oss-120b:free|GPT-OSS 120B|expansionist,o|nvidia/nemotron-3-ultra-550b-a55b:free|Nemotron 3 Ultra|outsider,x|moonshotai/kimi-k2.6:free|Kimi K2.6|executor"

# --- PAID-TIER PRESETS -------------------------------------------------------

# 2026 frontier flagships, 3 members (same as default in src/lib/board.ts)
# BOARD_ROSTER="opus|anthropic/claude-opus-4.7|Claude Opus 4.7,gemini|google/gemini-3.1-pro-preview|Gemini 3.1 Pro,qwen|qwen/qwen3-max|Qwen 3 Max"

# Frontier + dedicated chairman not on the panel (avoids self-bias). Sonnet 4.6
# only chairs; doesn't answer. Panel = 3 frontier voices.
# BOARD_ROSTER="opus|anthropic/claude-opus-4.7|Claude Opus 4.7,gemini|google/gemini-3.1-pro-preview|Gemini 3.1 Pro,qwen|qwen/qwen3-max|Qwen 3 Max,sonnet|anthropic/claude-sonnet-4.6|Claude Sonnet 4.6 (chair)"
# CHAIRMAN_ID=sonnet

# Budget paid, all under ~$1/Mtok in/out (Llama 4 + Mistral + Qwen Next)
# BOARD_ROSTER="llama|meta-llama/llama-4-maverick|Llama 4 Maverick,mistral|mistralai/mistral-large-2512|Mistral Large 2512,qwen|qwen/qwen3-next-80b-a3b-instruct|Qwen 3 Next 80B"

# Reasoning panel (slower, deeper). Sonnet chairs because reasoning models'
# visible chain-of-thought can leak into a streamed verdict.
# BOARD_ROSTER="o3|openai/o3|o3,r1|deepseek/deepseek-r1|DeepSeek R1,o4|openai/o4-mini|o4-mini,sonnet|anthropic/claude-sonnet-4.6|Claude Sonnet 4.6 (chair)"
# CHAIRMAN_ID=sonnet

# Mixed cheap + huge-context (Grok 4.20 has 2M context for $1.25/$2.5)
# BOARD_ROSTER="grok|x-ai/grok-4.20|Grok 4.20,llama|meta-llama/llama-4-maverick|Llama 4 Maverick,gemini|google/gemini-3.5-flash|Gemini 3.5 Flash"

# --- Chairman override -------------------------------------------------------
# Must match one of the ids above. Falls back to the first member if unset
# or invalid.
# CHAIRMAN_ID=opus

# --- OpenRouter attribution (optional) ---------------------------------------
# Shown in OpenRouter's dashboard and helps with model-routing analytics.
# OPENROUTER_REFERER=http://localhost:3000
# OPENROUTER_TITLE=llm-board
