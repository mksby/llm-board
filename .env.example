# OpenRouter API key — get one at https://openrouter.ai/keys
# Top up credits before running: https://openrouter.ai/credits
OPENROUTER_API_KEY=

# Optional: override the default board roster by listing OpenRouter model slugs
# Format: comma-separated `id:slug:label` triples. Leave empty to use the defaults in src/lib/board.ts.
# Example:
# BOARD_ROSTER=opus:anthropic/claude-opus-4:Claude Opus 4,gemini:google/gemini-2.5-pro:Gemini 2.5 Pro,qwen:qwen/qwen3-max:Qwen 3 Max

# Optional: override the default chairman id (must match one of the roster ids above)
# CHAIRMAN_ID=opus
